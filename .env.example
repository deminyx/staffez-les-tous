# Environnement — copier ce fichier en .env.local et remplir les valeurs

# Base de donnees PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/staffez_les_tous"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generer-avec-openssl-rand-base64-32"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# URL publique du site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# HelloAsso (lien externe campagne de don)
NEXT_PUBLIC_HELLOASSO_URL="https://www.helloasso.com/associations/staffez-les-tous"
